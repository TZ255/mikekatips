<!-- Home Page Variables -->
<% if (page === "index") { %>
<% title = `Tips na Utabiri wa Mechi za Leo` %>
<% description = `Pata tips za soka zinazoshinda na odds za uhakika. Tips za uhakika, mikeka ya bure na mechi za leo. Code za mikeka ya leo pamoja na utabiri wa mechi za kesho` %>
<% } %>

<!-- Date Page Variables -->
<% if (["index-date", "index-jana", "index-kesho"].includes(page)) { %>
<% title = `Tips na Utabiri wa Mechi za ${swahiliDay} ${currentDateDisplay}` %>
<% description = `Pata tips za soka zinazoshinda za ${swahiliDay}. Tips za bure, VIP na Premium. Shinda mikeka ya ${swahiliDay} kwa kutumia tips zetu za bure` %>
<% } %>

<!-- General Variables -->
<% keywords = `betting tips ${swahiliDay.toLowerCase()}, soka, michezo, tanzania, tips za soka, mkeka wa leo, mikeka ya bure, codes za betpawa, mechi za ${currentDateDisplay}` %>
<% page = page %>
<% page_url = page_url %>

<main class="bg-body-tertiary">
    <%- include('./extras/date-nav') %>

    <section class="py-4 py-lg-5 text-white" style="background:
        radial-gradient(circle at top right, rgba(255, 193, 7, 0.22), transparent 28%),
        radial-gradient(circle at bottom left, rgba(13, 110, 253, 0.18), transparent 30%),
        linear-gradient(135deg, #0f172a 0%, #16324f 50%, #1b4332 100%);">
        <div class="container">
            <div class="row align-items-center g-4 g-xl-5">
                <div class="col-12 col-xl-7">
                    <span class="badge rounded-pill px-3 py-2 mb-3 border border-light border-opacity-25 text-white fw-semibold" style="background: rgba(255,255,255,0.08);">
                        <i class="fa-solid fa-bolt text-warning me-2"></i>
                        MikekaTips • Tips za kila siku
                    </span>

                    <h1 class="display-4 fw-bold lh-sm mb-3" style="max-width: 20ch; text-wrap: balance;">
                       Tips na Utabiri wa Mechi za <%= swahiliDay %>
                    </h1>

                    <p class="lead text-white text-opacity-75 mb-4" style="max-width: 60ch;">
                        Pata free tips na premium picks za mechi za <%= swahiliDay.toLowerCase() %> <%= currentDateDisplay %>, pamoja na tabiri za ligi kubwa ulaya, ratiba, matokeo na msimamo wa ligi.
                    </p>

                    <div class="d-flex flex-wrap gap-2 mb-4">
                        <span class="badge rounded-pill text-bg-light text-dark px-3 py-2">Free tips kila siku</span>
                        <span class="badge rounded-pill text-bg-light text-dark px-3 py-2">Premium picks zenye uchambuzi</span>
                        <span class="badge rounded-pill text-bg-light text-dark px-3 py-2">Ligi kubwa Ulaya</span>
                    </div>

                </div>

                <div class="col-12 col-xl-5">
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3 border border-light border-opacity-25 rounded-4 p-3 p-md-4" style="background: rgba(255,255,255,0.08); backdrop-filter: blur(6px);">
                                <div class="d-flex align-items-start gap-3">
                                <div class="rounded-circle bg-warning text-dark d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 3rem; height: 3rem;">
                                    <i class="fa-solid fa-crown"></i>
                                </div>
                                <div>
                                    <div class="fw-bold mb-1">Premium Tips</div>
                                    <div class="text-white text-opacity-75">Pata tips zenye uchambuzi wa kina na tabiri zenye nafasi kubwa ya ushindi.</div>
                                </div>
                                </div>
                                <a href="/premium-tips" class="btn fw-semibold rounded-pill px-4 py-2 border-0 flex-shrink-0" style="background: linear-gradient(135deg, #f4d35e 0%, #ee964b 100%); color: #1f2937; box-shadow: 0 0.5rem 1.25rem rgba(238, 150, 75, 0.18);">
                                    <i class="fa-solid fa-crown me-2"></i>Premium
                                </a>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3 border border-light border-opacity-25 rounded-4 p-3 p-md-4" style="background: rgba(255,255,255,0.08); backdrop-filter: blur(6px);">
                                <div class="d-flex align-items-start gap-3">
                                <div class="rounded-circle bg-light text-primary d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 3rem; height: 3rem;">
                                    <i class="fa-solid fa-list-check"></i>
                                </div>
                                <div>
                                    <div class="fw-bold mb-1">Free Tips</div>
                                    <div class="text-white text-opacity-75">Pata tabiri za bure za kila siku, chambuzi na tabiri bora tanzania</div>
                                </div>
                                </div>
                                <a href="#free-tips" class="btn btn-outline-light rounded-pill px-4 py-2 flex-shrink-0">
                                    <i class="fa-solid fa-gift me-2"></i>Free Tips
                                </a>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3 border border-light border-opacity-25 rounded-4 p-3 p-md-4" style="background: rgba(255,255,255,0.08); backdrop-filter: blur(6px);">
                                <div class="d-flex align-items-start gap-3">
                                <div class="rounded-circle bg-light text-success d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 3rem; height: 3rem;">
                                    <i class="fa-solid fa-trophy"></i>
                                </div>
                                <div>
                                    <div class="fw-bold mb-1">League Tips</div>
                                    <div class="text-white text-opacity-75">Tabiri za bure za ligi kubwa Ulaya na Africa. Ratiba, matokeo na msimamo</div>
                                </div>
                                </div>
                                <a href="/prediction" class="btn btn-outline-light rounded-pill px-4 py-2 flex-shrink-0">
                                    <i class="fa-solid fa-arrow-up-right-from-square me-2"></i>Prediction
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <div class="container py-4 py-lg-5">

        <!-- Free Tips -->
        <div class="bg-white rounded-4 shadow-sm p-3 p-md-4">
            <%- include('./extras/free-tips-tab') %>
        </div>

        <!-- SEO Content -->
        <%- include('./extras/seo-content') %>
    </div>
</main>
