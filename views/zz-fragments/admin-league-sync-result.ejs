<%
  const alertClass = success ? (failed > 0 ? 'warning' : 'success') : 'danger';
  const title = success ? (failed > 0 ? 'League sync completed with some failures' : 'League sync completed') : 'League sync failed';
%>

<div class="alert alert-<%= alertClass %> border-0 mb-0">
    <div class="d-flex justify-content-between align-items-start gap-3">
        <div>
            <div class="fw-semibold mb-1"><%= title %></div>
            <% if (message) { %>
                <div class="small mb-2 fw-semibold">
                    <%= message %>
                </div>
            <% } %>
            <div class="small mb-2">
                <span><%= successful %>/<%= total %> leagues synced successfully.</span>
                <% if (failed > 0) { %>
                    <span><%= failed %> failed.</span>
                <% } %>
            </div>
            <div class="small text-muted">
                <%= new Date(syncedAt).toLocaleString('en-GB', { timeZone: 'Africa/Nairobi' }) %> EAT
            </div>
        </div>
        <span class="badge text-bg-<%= alertClass %>"><%= success ? 'Done' : 'Error' %></span>
    </div>

    <% if (results && results.length > 0) { %>
        <div class="mt-3">
            <% results.forEach(result => { %>
                <div class="d-flex justify-content-between align-items-center gap-3 py-2 border-top border-opacity-25">
                    <div>
                        <div class="fw-semibold"><%= result.leagueName || `League ${result.leagueId}` %></div>
                        <div class="small text-muted">League ID: <%= result.leagueId %></div>
                    </div>
                    <% if (result.success) { %>
                        <div class="small text-end">
                            <div><%= result.fixtures %> fixtures updated</div>
                            <div class="text-muted"><%= result.targetedFixtures %> tips refreshed</div>
                        </div>
                    <% } else { %>
                        <div class="small text-end text-danger"><%= result.error %></div>
                    <% } %>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>
